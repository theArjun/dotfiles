# Font
font-family = 0xProto Nerd Font
font-size = 18

# Window
window-decoration = false
window-padding-x = 5
window-padding-y = 5

# Appearance
background-opacity = 1
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# Shell
command = $HOME/workspace/misc/dotfiles/scripts/start_tmux.sh

# macOS
macos-titlebar-style = hidden

# Keybindings
keybind = ctrl+shift+f=toggle_fullscreen
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+t=new_window
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1

# Colors (Catppuccin Mocha)
background = 1e1e2e
foreground = d9e0ee

palette = 0=#1E1E2E
palette = 1=#F28FAD
palette = 2=#ABE9B3
palette = 3=#FAE3B0
palette = 4=#96CDFB
palette = 5=#F5C2E7
palette = 6=#89DCEB
palette = 7=#D9E0EE
palette = 8=#575268
palette = 9=#F28FAD
palette = 10=#ABE9B3
palette = 11=#FAE3B0
palette = 12=#96CDFB
palette = 13=#F5C2E7
palette = 14=#89DCEB
palette = 15=#D9E0EE

cursor-color = d9e0ee
cursor-text = 1e1e2e

selection-background = d9e0ee
selection-foreground = 1e1e2e
